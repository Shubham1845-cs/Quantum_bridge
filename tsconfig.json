{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@server/*": ["server/src/*"],
      "@shared/*": ["shared/*"],
      "@dashboard/*": ["apps/dashboard/src/*"],
      "@web/*": ["apps/web/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/dist"]
}
