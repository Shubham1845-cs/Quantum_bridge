# Server
NODE_ENV=development
PORT=3000
PROXY_PORT=8080

# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quantumbridge?retryWrites=true&w=majority

# JWT
JWT_SECRET=<min-32-chars-random-secret-here-replace-me>
JWT_REFRESH_SECRET=<min-32-chars-random-refresh-secret-replace>

# Redis (Upstash)
REDIS_URL=redis://default:<password>@<host>.upstash.io:6379

# CORS
ALLOWED_ORIGIN=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...

# Sentry
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Key Vault
PBKDF2_GLOBAL_PEPPER=<min-32-chars-random-pepper-here-replace>
